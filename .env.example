# Backend Environment Variables Template
# Copy this to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/
DB_NAME=legalcases

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# Service URLs (Update these after deployment)
EMBEDDING_SERVICE_URL=http://localhost:8000/embed
FAISS_SERVICE_URL=http://localhost:8001/search
FRONTEND_URL=http://localhost:5173

# Production URLs (Update after deploying)
# EMBEDDING_SERVICE_URL=https://legalcase-embed-service.onrender.com/embed
# FAISS_SERVICE_URL=https://legalcase-faiss-service.onrender.com/search
# FRONTEND_URL=https://legalcase-frontend.vercel.app
